# ============================================================
#  TRADRLY BOT — Variables d'environnement (exemple)
#  Copier ce fichier en .env et remplir les valeurs.
#  Le .env réel ne doit JAMAIS être commité.
# ============================================================

# --- Ports internes ---
UI_DEV_PORT=5173
ORCHESTRATOR_PORT=4000
AI_PORT=8000

# --- Clé de chiffrement du coffre de secrets (.env chiffré) ---
VAULT_MASTER_KEY=change-me-32-bytes-minimum-secret

# --- IA / LLM ---
OPENAI_API_KEY=sk-...
WHISPER_MODEL=base

# --- Compréhension d'intention (ajouter / supprimer un rdv, une tâche…) ---
# Gemini est GRATUIT : récupère ta clé sur https://aistudio.google.com/apikey
# puis colle-la ci-dessous. Sans clé, un repli local par règles est utilisé.
GEMINI_API_KEY=ta-cle-gemini-ici
GEMINI_MODEL=gemini-2.5-flash
# auto = Gemini puis OpenAI puis règles | forcer : gemini / openai / rules
INTENT_PROVIDER=auto

# --- TTS ---
TTS_PROVIDER=openai
TTS_VOICE=alloy

# --- Base de données / Mémoire vectorielle ---
SQLITE_PATH=./data/tradrly.db
CHROMA_PATH=./data/chroma

# --- Intégrations services ---
SLACK_BOT_TOKEN=
TEAMS_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
NOTION_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GITHUB_TOKEN=
GOOGLE_CALENDAR_CREDENTIALS=
